<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>

  <form action="/edit-project/<%= projectDetails.project_id %>" method="post">

    <div class="group-form">
      <label for="title">Title</label>
      <input 
        type="text" 
        id="title" 
        name="title" 
        value="<%= projectDetails.title %>" 
        required 
        maxlength="100" 
      />
    </div>

    
    <div class="group-form">
      <label for="description">Description</label>
      <textarea 
        name="description" 
        id="description" 
        required 
        maxlength="500"
      ><%= projectDetails.description %></textarea>
    </div>

    
    <div class="group-form">
      <label for="location">Location</label>
      <input 
        type="text" 
        id="location" 
        name="location" 
        value="<%= projectDetails.project_location %>" 
        required 
        maxlength="50" 
      />
    </div>

    
    <div class="group-form">
      <label for="date">Project Date</label>
      <input 
        type="date" 
        id="date" 
        name="date" 
        value="<%= projectDetails.project_date %>" 
        required 
      />
    </div>

    <!-- Organization Dropdown (Fixed EJS syntax and variable references) -->
    <div class="group-form">
      <label for="organization">Organization</label>
      <select name="organization_id" id="organization" required>
        <option value="">Select an Organization</option>
        <% organizations.forEach(org => { %>
          <option 
            value="<%= org.organization_id %>"
            <%= org.organization_id === projectDetails.organization_id ? 'selected' : '' %>
          >
            <%= org.name %>
          </option>
        <% }); %>
      </select>
    </div>

    <button type="submit">Update Project</button>

  </form>
</main>

<%- include('partials/footer') %>