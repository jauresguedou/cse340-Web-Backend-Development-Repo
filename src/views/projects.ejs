

<%- include('partials/header') %>
<main>
    <h2><%= title %></h2>
    <p>Here are our upcoming service projects:</p>
    <ul>
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <% const projectDate = new Date(project.project_date); %>
                <li>
                    <%= projectDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>:
                    <%= project.title %> (<%= project.organization_name %>)
                </li>
            <% }); %>
        <% } else { %>
            <li>No service projects are currently available.</li>
        <% } %>
    </ul>
</main>

<%- include('partials/footer') %>